#!/usr/bin/env bash

set -e
SCRIPT_DIR=$( cd -- "$( dirname -- "${0}" )" > /dev/null 2>&1 && pwd )
ROOT_DIR=$(realpath "$SCRIPT_DIR/..")

main() {

  require_git_clean
  detect_gem_version
  require_versions_match
  log "Building all artifacts and docs"
  bin/build

  log "Releasing Gem"
  rake release
  release_node_packages
  wait_for_rubygems
  bin/build-docker-image -g "${GEM_VERSION}" -p
}

log() {
  echo "[ bin/publish ] ${*}"
}

usage() {
  echo "Usage: $0"
  echo
  echo "    Publish Ruby Gem, Node modules, and Docker image"
  echo
}

release_node_packages() {
  cd brut-js
  log "Releasing brut-js NPM package"
  bin/publish
  cd ../brut-css
  log "Releasing brut-css NPM package"
  bin/publish
  log "Finished releasing NPM packages"
  cd ..
}


wait_for_rubygems() {
  timeout=60
  interval=2
  elapsed=0

  log "Waiting ${timeout} seconds for brut $GEM_VERSION to be available on RubyGems"
  log "This is because the Docker image requires installing the gem"
  while (( elapsed < timeout )); do
    if gem list -r "brut" -a | grep -q "$GEM_VERSION"; then
      log "brut $GEM_VERSION is available on RubyGems"
      return 0
    fi
    sleep $interval
    (( elapsed += interval ))
  done

  log "brut $GEM_VERSION is not available on RubyGems after $timeout seconds"
  log "Something may have gone wrong. Or, it could just be taking a while"
  log "Either way, the Docker image cannot be build and you will have to manually"
  log "re-run various parts of this script. Sorry."
  exit 1
}


require_git_clean() {
  git diff --quiet --exit-code HEAD --
  if git diff --quiet --exit-code HEAD --; then
    log "Git working directory is clean"
  else
    log "Git working directory is not clean. Please commit or stash your changes before publishing."
    exit 1
  fi
}

detect_gem_version() {

  GEM_VERSION=$( rake -T | grep "rake install " | sed 's/^.*brut-//g' | sed 's/\.gem.*$//g')
  if [[ "$GEM_VERSION" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
    log "Releasing version ${GEM_VERSION}"
  else
    log "Version '${GEM_VERSION}' does not look like a version: X.Y.Z"
    exit 1
  fi
}

require_versions_match() {
  local brutjs_version=$(ruby -rjson -e "puts JSON.parse(File.read('brut-js/package.json')).fetch('version')")
  local brutcss_version=$(ruby -rjson -e "puts JSON.parse(File.read('brut-css/package.json')).fetch('version')")
  if [ $GEM_VERSION != $brutjs_version ] || [ $GEM_VERSION != $brutcss_version ]; then
    log "Version mismatch detected:"
    log "  brut gem version              : $GEM_VERSION"
    log "  brut-js package.json version  : $brutjs_version"
    log "  brut-css package.json version : $brutcss_version"
    log "Please ensure all versions match before publishing."
    exit 1
  fi
}

for arg in "${@}"; do
  if [ "${arg}" = "-h" ] || [ "${arg}" = "--help" ] || [ "${arg}" = "help" ]; then
    usage
    exit 0
  fi
done

main
